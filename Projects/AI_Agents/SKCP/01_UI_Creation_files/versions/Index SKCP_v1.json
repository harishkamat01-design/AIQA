// ── QUOTE BUILDER ────────────────────────────────────────────────
const quoteItems = [];
function addQuoteItem() {
  const sel = document.getElementById('q-product').value;
  if (!sel) return;
  const [name, price] = sel.split('|');
  const qty = Math.max(1, parseInt(document.getElementById('q-qty').value) || 1);
  const disc = Math.min(30, Math.max(0, parseFloat(document.getElementById('q-disc').value) || 0));
  quoteItems.push({ name, price: parseInt(price), qty, disc });
  document.getElementById('q-prev-name').textContent = document.getElementById('q-customer').value || '—';
  document.getElementById('q-prev-terms').textContent = document.getElementById('q-terms').value;
  renderQuote();
}
function renderQuote() {
  if (!quoteItems.length) {
    document.getElementById('quote-items').innerHTML = '<div style="font-size:12px;color:var(--text3);padding:24px 0;text-align:center">Add products to build your quote</div>';
    updateTotals(0); return;
  }
  let html = '', total = 0;
  quoteItems.forEach((it, i) => {
    const line = it.price * it.qty * (1 - it.disc / 100); total += line;
    html += `<div class="quote-item"><div class="qi-name">${it.name}${it.disc > 0 ? ` <span style="font-size:10px;color:var(--text3)">(${it.disc}% off)</span>` : ''}</div><input class="qi-qty" type="number" value="${it.qty}" min="1" style="width:65px;font-size:11px;padding:4px 7px;background:var(--bg3);border:0.5px solid var(--border);border-radius:6px;color:var(--text)" onchange="updateQty(${i},this.value)"><div class="qi-price">₹${Math.round(line).toLocaleString('en-IN')}</div><div class="qi-del" onclick="removeItem(${i})"><i class="ti ti-x"></i></div></div>`;
  });
  document.getElementById('quote-items').innerHTML = html;
  updateTotals(total);
}
function updateTotals(sub) {
  const gst = Math.round(sub * 0.18);
  document.getElementById('q-subtotal').textContent = '₹' + Math.round(sub).toLocaleString('en-IN');
  document.getElementById('q-gst').textContent = '₹' + gst.toLocaleString('en-IN');
  document.getElementById('q-total').textContent = '₹' + (Math.round(sub) + gst).toLocaleString('en-IN');
}
function updateQty(i, v) { quoteItems[i].qty = Math.max(1, parseInt(v) || 1); renderQuote(); }
function removeItem(i) { quoteItems.splice(i, 1); renderQuote(); }
function clearQuote() { quoteItems.length = 0; renderQuote(); document.getElementById('q-customer').value = ''; document.getElementById('q-prev-name').textContent = '—'; }
function sendQuote() { showAlert('quote-alert'); }
function openQuote(val) { nav('quote', null); setTimeout(() => { document.getElementById('q-product').value = val; }, 100); }

