      <div style="flex:1">
        <div class="labour-name">${l.name}</div>
        <div class="labour-role">${l.role} · ₹${l.wage}/day${times ? ' · ' + times : ''}</div>
      </div>
      ${badge}
      <button class="checkin-btn ${btnClass}" onclick="toggleCheckin(${l.id})">${btnLabel}</button>
    </div>`;
  }).join('');
}
function addLabour() {
  const name = document.getElementById('l-name').value.trim();
  if (!name) return;
