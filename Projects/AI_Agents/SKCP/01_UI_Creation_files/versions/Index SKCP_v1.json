// ── TIMESHEET ────────────────────────────────────────────────────
function getDaysInMonth(year, month) { return new Date(year, month + 1, 0).getDate(); }
function isSunday(year, month, day) { return new Date(year, month, day).getDay() === 0; }

// Indian Holidays 2026
const indianHolidays2026 = {
  '2026-01-14': "Makar Sankranti",
  '2026-01-26': "Republic Day",
  '2026-03-03': "Holi",
  '2026-03-27': "Good Friday",
  '2026-04-06': "Ram Navami",
  '2026-04-14': "Dr. Ambedkar Jayanti",
  '2026-04-14b': "Vaisakhi",
  '2026-05-01': "Maharashtra Day / Labour Day",
  '2026-05-15': "Buddha Purnima",
  '2026-06-17': "Eid ul-Adha",
  '2026-08-15': "Independence Day",
  '2026-08-26': "Janmashtami",
  '2026-09-02': "Ganesh Chaturthi",
  '2026-09-19': "Milad-un-Nabi",
  '2026-10-02': "Gandhi Jayanti",
  '2026-10-21': "Dussehra / Vijayadashami",
  '2026-10-31': "Halloween (observance)",
  '2026-11-01': "Diwali",
  '2026-11-02': "Diwali (Lakshmi Puja)",
  '2026-11-15': "Guru Nanak Jayanti",
  '2026-12-25': "Christmas Day",
};

function getHolidayKey(year, month, day) {
  const k = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
  return indianHolidays2026[k] || null;
}

// Simulated attendance: P=present, A=absent, H=half, X=holiday/Sunday
function simulateAttendance(labourIdx, year, month, day) {
  if (isSunday(year, month, day)) return 'X';
  if (getHolidayKey(year, month, day)) return 'X';
  const seed = (labourIdx * 31 + day * 7 + month * 13) % 100;
  if (seed < 75) return 'P';
  if (seed < 88) return 'H';
  return 'A';
}

function renderTimesheet() {
  const month = parseInt(document.getElementById('ts-month').value);
  const year = parseInt(document.getElementById('ts-year').value);
  const days = getDaysInMonth(year, month);
  document.getElementById('ts-workdays').textContent = days - [...Array(days)].filter((_,i) => isSunday(year,month,i+1) || getHolidayKey(year,month,i+1)).length;

  // Header
  let hdr = '<tr><th style="text-align:left;padding:5px 8px;white-space:nowrap">Name</th>';
  for (let d = 1; d <= days; d++) {
    const isSun = isSunday(year, month, d);
    const isHol = getHolidayKey(year, month, d);
    hdr += `<th class="ts-cell" style="${isSun||isHol ? 'color:var(--text3)' : ''}">${d}</th>`;
  }
  hdr += '<th class="ts-cell">P</th><th class="ts-cell">A</th><th class="ts-cell">Wages</th></tr>';
  document.getElementById('ts-head').innerHTML = hdr;

  // Rows
  let rows = '';
  labourData.forEach((l, li) => {
    let p=0, a=0, h=0;
    let row = `<tr><td style="padding:5px 8px;white-space:nowrap;color:var(--text);font-size:11px">${l.name.split(' ')[0]}</td>`;
    for (let d = 1; d <= days; d++) {
      const att = simulateAttendance(li, year, month, d);
      if (att==='P') { p++; row += `<td class="ts-cell present">P</td>`; }
      else if (att==='A') { a++; row += `<td class="ts-cell absent">A</td>`; }
      else if (att==='H') { h++; p+=0.5; row += `<td class="ts-cell half">½</td>`; }
      else { row += `<td class="ts-cell holiday">—</td>`; }
    }
    const wages = Math.round((p + h*0.5) * l.wage);
    row += `<td class="ts-cell present" style="font-weight:500">${Math.round(p)}</td><td class="ts-cell absent" style="font-weight:500">${a}</td><td class="ts-cell" style="color:var(--accent);font-weight:500">₹${wages.toLocaleString('en-IN')}</td></tr>`;
    rows += row;
  });
  document.getElementById('ts-body').innerHTML = rows;
}

function initAttendChart() {
  if (chartsReady.attend) return; chartsReady.attend = true;
  const attPct = [94,91,96,89,93,88,0,0,0,0,0,0];
  new Chart(document.getElementById('c-attend'), {
    type: 'bar',
    data: { labels:['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'], datasets:[{label:'Attendance %', data:attPct, backgroundColor: attPct.map(v => v===0?'rgba(255,255,255,0.05)':'#C4A882'), borderRadius:4}] },
    options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}, scales:{x:{grid:{color:gc},ticks:{color:tc,font:{size:10}}},y:{grid:{color:gc},ticks:{color:tc,font:{size:10},callback:v=>v+'%'},max:100,min:0}} }
  });
}

// ── CALENDAR ─────────────────────────────────────────────────────
let calYear = 2026, calMonth = 5; // June 2026
const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];

function renderCalendar() {
  document.getElementById('cal-label').textContent = `${monthNames[calMonth]} ${calYear}`;
  const days = getDaysInMonth(calYear, calMonth);
  const firstDay = new Date(calYear, calMonth, 1).getDay();
  const today = new Date();
  let html = '';
  for (let i = 0; i < firstDay; i++) html += '<div class="cal-cell empty"></div>';
  for (let d = 1; d <= days; d++) {
    const isToday = d === today.getDate() && calMonth === today.getMonth() && calYear === today.getFullYear();
    const isSun = isSunday(calYear, calMonth, d);
    const hol = getHolidayKey(calYear, calMonth, d);
    let cls = 'cal-cell';
    if (isToday) cls += ' today';
    else if (hol) cls += ' holiday';
    else if (isSun) cls += ' weekend';
    const shortHol = hol ? `<div class="cal-holiday-name">${hol.length > 14 ? hol.substring(0,12)+'…' : hol}</div>` : '';
    html += `<div class="${cls}"><div class="cal-num">${d}</div>${shortHol}</div>`;
  }
  document.getElementById('cal-grid').innerHTML = html;

  // Holiday list table
  const hlRows = Object.entries(indianHolidays2026).map(([k, v]) => {
    const [y, m, d] = k.split('-').map(Number);
    const dt = new Date(y, m-1, d);
    const dayName = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'][dt.getDay()];
    const type = ['Republic Day','Independence Day','Gandhi Jayanti'].includes(v) ? 'National' : 'Public/Bank';
    return { ts: dt.getTime(), row: `<tr><td>${d} ${monthNames[m-1]} ${y}</td><td>${dayName}</td><td>${v}</td><td><span class="badge ${type==='National'?'br':'bi'}">${type}</span></td></tr>` };
  });
  hlRows.sort((a,b)=>a.ts-b.ts);
  document.getElementById('holiday-list').innerHTML = hlRows.map(r=>r.row).join('');
}

function calNav(dir) {
  calMonth += dir;
  if (calMonth > 11) { calMonth = 0; calYear++; }
  if (calMonth < 0) { calMonth = 11; calYear--; }
  renderCalendar();
}

// ── INIT ─────────────────────────────────────────────────────────
initCharts();
renderCalendar();
</script>
</body>
</html>
