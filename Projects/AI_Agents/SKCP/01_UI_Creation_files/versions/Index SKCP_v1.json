<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sri Kundodhari Cement Products — B2B Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<style>
:root {
  --bg: #0f1117;
  --bg2: #181b23;
  --bg3: #1e2130;
  --border: rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.15);
  --text: #f0f0f0;
  --text2: #9ba0b0;
  --text3: #5c6070;
  --accent: #C4A882;
  --accent2: #a8895f;
  --green: #4CAF7D;
  --amber: #E8A317;
  --red: #E24B4A;
  --blue: #378ADD;
  --success-bg: rgba(76,175,125,0.15);
  --success-text: #6de0a5;
  --warning-bg: rgba(232,163,23,0.15);
  --warning-text: #f0c060;
  --danger-bg: rgba(226,75,74,0.15);
  --danger-text: #f08080;
  --info-bg: rgba(55,138,221,0.15);
  --info-text: #7ab8f5;
  --radius: 8px;
  --radius-lg: 12px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column}
.app{display:flex;flex:1;min-height:100vh}

/* SIDEBAR */
.sidebar{width:220px;flex-shrink:0;background:var(--bg2);border-right:0.5px solid var(--border);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto}
.brand{padding:18px 16px;border-bottom:0.5px solid var(--border)}
.brand-logo{width:40px;height:40px;background:var(--accent);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;margin-bottom:10px}
.brand-logo i{font-size:22px;color:#1a1208}
.brand-name{font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:700;color:var(--text);line-height:1.2}
.brand-sub{font-size:10px;color:var(--text3);letter-spacing:.06em;margin-top:2px}
.nav-section{padding:6px 0}
.nav-label{font-size:10px;color:var(--text3);letter-spacing:.08em;padding:10px 16px 4px;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 16px;font-size:12.5px;color:var(--text2);cursor:pointer;border-left:2px solid transparent;transition:all .12s;user-select:none}
.nav-item:hover{background:var(--bg3);color:var(--text)}
.nav-item.active{color:var(--accent);border-left-color:var(--accent);background:var(--bg3)}
.nav-item i{font-size:16px}
.nav-badge{margin-left:auto;font-size:10px;padding:1px 6px;border-radius:99px;background:var(--danger-bg);color:var(--danger-text);font-weight:500}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;min-width:0}
.topbar{display:flex;align-items:center;gap:10px;padding:12px 20px;border-bottom:0.5px solid var(--border);background:var(--bg2);position:sticky;top:0;z-index:10}
.topbar-title{font-family:'Rajdhani',sans-serif;font-size:18px;font-weight:700;color:var(--text);flex-shrink:0}
.topbar-search{flex:1;max-width:280px}
.topbar-search input{width:100%;background:var(--bg3);border:0.5px solid var(--border);border-radius:var(--radius);color:var(--text);font-size:12px;padding:7px 12px;outline:none}
.topbar-search input:focus{border-color:var(--accent)}
.topbar-btn{display:flex;align-items:center;gap:5px;padding:7px 13px;font-size:12px;cursor:pointer;border:0.5px solid var(--border2);border-radius:var(--radius);background:transparent;color:var(--text2);transition:all .12s;white-space:nowrap}
.topbar-btn:hover{background:var(--bg3);color:var(--text)}
.topbar-btn.primary{background:var(--accent);border-color:var(--accent);color:#1a1208;font-weight:600}
.topbar-btn.primary:hover{background:var(--accent2)}
.content{padding:20px;flex:1}
.section{display:none}
.section.active{display:block}

/* KPI GRID */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:16px}
.kpi{background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:14px 16px;position:relative;overflow:hidden}
.kpi::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent)}
.kpi.green::before{background:var(--green)}
.kpi.amber::before{background:var(--amber)}
.kpi.red::before{background:var(--red)}
.kpi.blue::before{background:var(--blue)}
.kpi-label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px}
.kpi-val{font-family:'Rajdhani',sans-serif;font-size:24px;font-weight:700;color:var(--text);line-height:1}
.kpi-delta{font-size:10px;margin-top:3px;color:var(--text3)}
.kpi-delta.up{color:var(--green)}
.kpi-delta.dn{color:var(--amber)}

/* CARDS */
.card{background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:16px;margin-bottom:14px}
.card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.card-title{font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:600;color:var(--text);display:flex;align-items:center;gap:7px}
.card-title i{font-size:18px;color:var(--accent)}
.card-action{font-size:11px;color:var(--info-text);cursor:pointer}
.card-action:hover{text-decoration:underline}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.row3{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:14px}

/* CHARTS */
.ch{position:relative;width:100%;height:180px}
.ch-tall{height:220px}

/* TABLES */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:left;padding:7px 10px;color:var(--text3);font-weight:500;border-bottom:0.5px solid var(--border);font-size:10px;text-transform:uppercase;letter-spacing:.04em}
td{padding:8px 10px;color:var(--text);border-bottom:0.5px solid var(--border)}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--bg3)}

/* BADGES */
.badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:99px;font-size:10px;font-weight:500;white-space:nowrap}
.bg{background:var(--success-bg);color:var(--success-text)}
.ba{background:var(--warning-bg);color:var(--warning-text)}
.br{background:var(--danger-bg);color:var(--danger-text)}
.bi{background:var(--info-bg);color:var(--info-text)}

/* PROGRESS */
.prog{height:5px;background:var(--bg3);border-radius:99px;overflow:hidden;margin-top:4px}
.progf{height:100%;border-radius:99px;background:var(--accent)}
.progf.lo{background:var(--amber)}
.progf.ok{background:var(--green)}
.progf.cr{background:var(--red)}

/* FORMS */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.form-field{display:flex;flex-direction:column;gap:4px}
.form-field.full{grid-column:1/-1}
.form-field label{font-size:11px;color:var(--text2)}
.form-field input,.form-field select,.form-field textarea{background:var(--bg3);border:0.5px solid var(--border);border-radius:var(--radius);color:var(--text);font-size:12px;padding:7px 10px;outline:none;width:100%;transition:border-color .12s}
.form-field input:focus,.form-field select:focus,.form-field textarea:focus{border-color:var(--accent)}
.form-field textarea{min-height:65px;resize:vertical}
.form-field select option{background:var(--bg2)}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:8px 16px;border:0.5px solid var(--border2);border-radius:var(--radius);font-size:12px;font-weight:500;cursor:pointer;transition:all .12s;background:transparent;color:var(--text)}
.btn:hover{background:var(--bg3)}
.btn.primary{background:var(--accent);border-color:var(--accent);color:#1a1208}
.btn.primary:hover{background:var(--accent2)}
.btn.success{background:var(--success-bg);border-color:var(--green);color:var(--success-text)}
.btn.danger{background:var(--danger-bg);border-color:var(--red);color:var(--danger-text)}
.btn-row{display:flex;gap:8px;margin-top:12px;flex-wrap:wrap}

/* ALERTS */
.alert{display:none;padding:10px 14px;border-radius:var(--radius);font-size:12px;margin-top:10px;border:0.5px solid}
.alert.success{background:var(--success-bg);color:var(--success-text);border-color:var(--green)}
.alert.show{display:block}

/* AVATAR */
.avatar{width:34px;height:34px;border-radius:50%;background:var(--info-bg);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--info-text);flex-shrink:0}

/* LEDGER */
.ledger-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:0.5px solid var(--border);font-size:12px}
.ledger-row:last-child{border:none}
.credit{color:var(--success-text);font-weight:500}
.debit{color:var(--danger-text);font-weight:500}

/* PIPELINE */
.pipeline-stage{padding:10px;background:var(--bg3);border-radius:var(--radius);margin-bottom:8px;border:0.5px solid var(--border)}
.ps-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.ps-label{font-size:12px;font-weight:500;color:var(--text)}
.ps-count{font-size:10px;color:var(--text3)}
.ps-item{font-size:11px;color:var(--text2);padding:4px 8px;background:var(--bg2);border-radius:var(--radius);margin-bottom:3px;border:0.5px solid var(--border);display:flex;justify-content:space-between}

/* DELIVERY TRACKER */
.delivery-track{display:flex;gap:0;margin:14px 0}
.dt-step{flex:1;text-align:center;position:relative}
.dt-step::before{content:'';position:absolute;top:13px;left:-50%;right:50%;height:2px;background:var(--border2)}
.dt-step:first-child::before{display:none}
.dt-step.done::before{background:var(--accent)}
.dt-dot{width:28px;height:28px;border-radius:50%;border:2px solid var(--border2);background:var(--bg2);display:flex;align-items:center;justify-content:center;margin:0 auto 6px;font-size:12px;position:relative;z-index:1}
.dt-step.done .dt-dot{border-color:var(--accent);background:var(--accent);color:#1a1208}
.dt-step.active .dt-dot{border-color:var(--accent);color:var(--accent)}
.dt-label{font-size:10px;color:var(--text3)}
.dt-step.done .dt-label,.dt-step.active .dt-label{color:var(--text2)}

/* NOTIF */
.notif-item{display:flex;gap:10px;padding:10px 0;border-bottom:0.5px solid var(--border)}
.notif-item:last-child{border:none}
.notif-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px}
.notif-text{font-size:12px;color:var(--text);line-height:1.5}
.notif-time{font-size:10px;color:var(--text3);margin-top:3px}

/* TOGGLE */
.toggle{width:38px;height:20px;background:var(--border2);border-radius:99px;position:relative;cursor:pointer;flex-shrink:0}
.toggle.on{background:var(--green)}
.toggle::after{content:'';position:absolute;width:14px;height:14px;border-radius:50%;background:white;top:3px;left:3px;transition:left .15s}
.toggle.on::after{left:21px}
.settings-row{display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:0.5px solid var(--border)}
.settings-row:last-child{border:none}
.settings-label{font-size:12.5px;color:var(--text)}
.settings-sub{font-size:10px;color:var(--text3);margin-top:2px}

/* QUOTE BUILDER */
.quote-item{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:0.5px solid var(--border);font-size:12px}
.quote-item:last-child{border:none}
.qi-name{flex:1;color:var(--text)}
.qi-qty input{width:65px;font-size:11px;padding:4px 7px}
.qi-price{min-width:80px;text-align:right;font-weight:500;color:var(--text)}
.qi-del{color:var(--text3);cursor:pointer;font-size:16px;margin-left:4px}
.qi-del:hover{color:var(--red)}
.total-bar{display:flex;justify-content:space-between;align-items:baseline;padding:8px 0;border-top:0.5px solid var(--border);margin-top:6px}
.total-label{font-size:12px;color:var(--text2)}
.total-val{font-family:'Rajdhani',sans-serif;font-size:20px;font-weight:700;color:var(--text)}

/* CUSTOMER CARD */
.customer-card{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:0.5px solid var(--border)}
.customer-card:last-child{border:none}

/* CALENDAR */
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.cal-header{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:4px}
.cal-day-name{font-size:10px;color:var(--text3);text-align:center;padding:4px}
.cal-cell{min-height:42px;padding:4px;border-radius:6px;border:0.5px solid transparent;cursor:pointer;transition:all .1s}
.cal-cell:hover{background:var(--bg3);border-color:var(--border)}
.cal-cell.empty{cursor:default}
.cal-cell.today{background:var(--bg3);border-color:var(--accent)}
.cal-cell.holiday{background:var(--danger-bg);border-color:var(--red)}
.cal-cell.weekend{background:var(--bg3)}
.cal-num{font-size:11px;font-weight:500;color:var(--text2);text-align:center}
.cal-cell.today .cal-num{color:var(--accent);font-weight:700}
.cal-cell.holiday .cal-num{color:var(--danger-text)}
.cal-holiday-name{font-size:8.5px;color:var(--danger-text);text-align:center;line-height:1.2;margin-top:1px}
.cal-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.cal-nav-btn{padding:5px 10px;cursor:pointer;border:0.5px solid var(--border);border-radius:var(--radius);background:transparent;color:var(--text);font-size:12px}
.cal-nav-btn:hover{background:var(--bg3)}
.cal-month-label{font-family:'Rajdhani',sans-serif;font-size:16px;font-weight:700;color:var(--text)}
.cal-legend{display:flex;gap:14px;margin-top:10px;flex-wrap:wrap}
.cal-legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text2)}
.cal-legend-dot{width:10px;height:10px;border-radius:3px}

/* LABOUR */
.labour-card{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:0.5px solid var(--border)}
.labour-card:last-child{border:none}
.labour-avatar{width:34px;height:34px;border-radius:50%;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--accent);flex-shrink:0;border:0.5px solid var(--border)}
.labour-name{font-size:12.5px;font-weight:500;color:var(--text)}
.labour-role{font-size:10px;color:var(--text3)}
.checkin-btn{padding:5px 12px;font-size:11px;border-radius:99px;cursor:pointer;border:0.5px solid;font-weight:500;transition:all .12s}
.checkin-btn.in{background:var(--success-bg);border-color:var(--green);color:var(--success-text)}
.checkin-btn.out{background:var(--danger-bg);border-color:var(--red);color:var(--danger-text)}

/* TIMESHEET */
.ts-cell{text-align:center;font-size:11px;padding:5px 3px}
.ts-cell.present{color:var(--success-text)}
.ts-cell.absent{color:var(--danger-text)}
.ts-cell.half{color:var(--warning-text)}
.ts-cell.holiday{color:var(--text3)}
.ts-cell.sunday{color:var(--text3)}

/* SHOP */
.product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px}
.product-card{background:var(--bg3);border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:14px;cursor:pointer;transition:border-color .12s}
.product-card:hover{border-color:var(--accent)}
.product-icon{font-size:30px;color:var(--accent);margin-bottom:8px}
.product-name{font-size:12px;font-weight:500;color:var(--text);margin-bottom:3px}
.product-price{font-family:'Rajdhani',sans-serif;font-size:17px;font-weight:700;color:var(--text)}
.product-sku{font-size:10px;color:var(--text3);margin-bottom:8px}
.add-btn{display:block;text-align:center;padding:5px;background:var(--info-bg);color:var(--info-text);border-radius:var(--radius);font-size:11px;cursor:pointer;transition:background .12s}
.add-btn:hover{background:var(--blue);color:white}

/* MAP */
.map-placeholder{background:var(--bg3);border-radius:var(--radius-lg);min-height:220px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;color:var(--text3);font-size:13px;border:0.5px solid var(--border)}

/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.contact-item{display:flex;align-items:flex-start;gap:10px;padding:12px;background:var(--bg3);border-radius:var(--radius);border:0.5px solid var(--border)}
.contact-icon{width:34px;height:34px;border-radius:50%;background:rgba(196,168,130,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.contact-icon i{font-size:16px;color:var(--accent)}
.contact-label{font-size:10px;color:var(--text3);margin-bottom:2px}
.contact-val{font-size:12.5px;color:var(--text);font-weight:500}

/* TIMING */
.timing-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:0.5px solid var(--border)}
.timing-row:last-child{border:none}
.timing-day{font-size:13px;color:var(--text)}
.timing-hours{font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:600;color:var(--text)}

/* RESPONSIVE */
@media(max-width:768px){
  .sidebar{display:none}
  .row2,.row3{grid-template-columns:1fr}
  .contact-grid{grid-template-columns:1fr}
  .form-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>
<div class="app">

<!-- SIDEBAR -->
<nav class="sidebar">
  <div class="brand">
    <div class="brand-logo"><i class="ti ti-building-factory-2"></i></div>
    <div class="brand-name">Sri Kundodhari<br>Cement Products</div>
    <div class="brand-sub">B2B Management Portal</div>
  </div>
  <div class="nav-section">
    <div class="nav-label">Operations</div>
    <div class="nav-item active" onclick="nav('overview',this)"><i class="ti ti-layout-dashboard"></i>Overview</div>
    <div class="nav-item" onclick="nav('orders',this)"><i class="ti ti-file-invoice"></i>Orders<span class="nav-badge">4</span></div>
    <div class="nav-item" onclick="nav('quote',this)"><i class="ti ti-calculator"></i>Quote Builder</div>
    <div class="nav-item" onclick="nav('inventory',this)"><i class="ti ti-package"></i>Inventory</div>
    <div class="nav-item" onclick="nav('production',this)"><i class="ti ti-settings-2"></i>Production</div>
    <div class="nav-item" onclick="nav('rawmat',this)"><i class="ti ti-truck"></i>Raw Materials</div>
  </div>
  <div class="nav-section">
    <div class="nav-label">B2B</div>
    <div class="nav-item" onclick="nav('customers',this)"><i class="ti ti-building"></i>Customers</div>
    <div class="nav-item" onclick="nav('pipeline',this)"><i class="ti ti-chart-dots"></i>Sales Pipeline</div>
    <div class="nav-item" onclick="nav('ledger',this)"><i class="ti ti-receipt-2"></i>Ledger</div>
    <div class="nav-item" onclick="nav('dispatch',this)"><i class="ti ti-map-pin"></i>Dispatch</div>
  </div>
  <div class="nav-section">
    <div class="nav-label">HR</div>
    <div class="nav-item" onclick="nav('labour',this)"><i class="ti ti-users"></i>Labour</div>
    <div class="nav-item" onclick="nav('timesheet',this)"><i class="ti ti-calendar-stats"></i>Timesheet</div>
  </div>
  <div class="nav-section">
    <div class="nav-label">Business</div>
    <div class="nav-item" onclick="nav('shop',this)"><i class="ti ti-shopping-bag"></i>Daily Shop</div>
    <div class="nav-item" onclick="nav('calendar',this)"><i class="ti ti-calendar"></i>Calendar 2026</div>
    <div class="nav-item" onclick="nav('map',this)"><i class="ti ti-map-2"></i>Location</div>
    <div class="nav-item" onclick="nav('contact',this)"><i class="ti ti-phone"></i>Contact</div>
  </div>
  <div class="nav-section">
    <div class="nav-label">Admin</div>
    <div class="nav-item" onclick="nav('notifications',this)"><i class="ti ti-bell"></i>Alerts<span class="nav-badge">3</span></div>
    <div class="nav-item" onclick="nav('reports',this)"><i class="ti ti-chart-bar"></i>Reports</div>
    <div class="nav-item" onclick="nav('settings',this)"><i class="ti ti-settings"></i>Settings</div>
  </div>
</nav>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="topbar-title" id="page-title">Overview</div>
    <div class="topbar-search"><input placeholder="Search orders, customers, products…" id="search-input"></div>
    <button class="topbar-btn"><i class="ti ti-download"></i> Export</button>
    <button class="topbar-btn primary" onclick="nav('quote',null)"><i class="ti ti-plus"></i> New Quote</button>
  </div>

  <div class="content">

    <!-- OVERVIEW -->
    <div id="sec-overview" class="section active">
      <div class="kpi-grid">
        <div class="kpi green"><div class="kpi-label">Revenue MTD</div><div class="kpi-val">₹9.8L</div><div class="kpi-delta up">▲ +14% vs last month</div></div>
