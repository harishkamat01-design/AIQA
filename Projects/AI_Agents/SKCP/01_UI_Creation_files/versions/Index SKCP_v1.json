function updateTime() { document.getElementById('l-time').textContent = new Date().toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}); }
function toggleCheckin(id) {
  const w = labourData.find(l => l.id === id);
  if (!w) return;
  const now = new Date().toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'});
  if (w.status === 'absent') { w.status = 'in'; w.checkin = now; w.checkout = ''; }
  else if (w.status === 'in') { w.status = 'out'; w.checkout = now; }
  else { w.status = 'in'; w.checkin = now; w.checkout = ''; }
  renderLabour();
}
function renderLabour() {
  const present = labourData.filter(l => l.status === 'in' || l.status === 'out').length;
  const absent = labourData.filter(l => l.status === 'absent').length;
  document.getElementById('l-present').textContent = labourData.filter(l => l.status === 'in').length;
  document.getElementById('l-absent').textContent = absent;
  document.getElementById('labour-list').innerHTML = labourData.map(l => {
    const isIn = l.status === 'in', isOut = l.status === 'out', isAbsent = l.status === 'absent';
    const initials = l.name.split(' ').map(n => n[0]).join('').substring(0,2);
    const btnLabel = isIn ? 'Check Out' : isAbsent ? 'Check In' : 'Check In Again';
    const btnClass = isIn ? 'out' : 'in';
    const badge = isIn ? '<span class="badge bg">Present</span>' : isOut ? '<span class="badge ba">Checked Out</span>' : '<span class="badge br">Absent</span>';
    const times = (l.checkin ? `In: ${l.checkin}` : '') + (l.checkout ? ` · Out: ${l.checkout}` : '');
    return `<div class="labour-card">
