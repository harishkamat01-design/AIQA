// ── NAV ──────────────────────────────────────────────────────────
const pageTitles = {overview:'Overview',orders:'Orders',quote:'Quote Builder',inventory:'Inventory',production:'Production',rawmat:'Raw Materials',customers:'Customers',pipeline:'Sales Pipeline',ledger:'Ledger',dispatch:'Dispatch',labour:'Labour',timesheet:'Timesheet',shop:'Daily Shop',calendar:'Calendar 2026',map:'Location',contact:'Contact',notifications:'Alerts',reports:'Reports',settings:'Settings'};
function nav(id, el) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('sec-' + id).classList.add('active');
  if (el) el.classList.add('active');
  else {
    document.querySelectorAll('.nav-item').forEach(n => { if (n.textContent.trim().startsWith(pageTitles[id]?.substring(0,5) || '?')) n.classList.add('active'); });
  }
  document.getElementById('page-title').textContent = pageTitles[id] || id;
  if (id === 'overview') initCharts();
  if (id === 'production') initProdChart();
  if (id === 'reports') initMarginChart();
  if (id === 'timesheet') { renderTimesheet(); initAttendChart(); }
  if (id === 'labour') updateTime();
  if (id === 'calendar') renderCalendar();
}

function showAlert(id) {
  const a = document.getElementById(id);
  if (!a) return;
  a.classList.add('show');
  setTimeout(() => a.classList.remove('show'), 3500);
}

