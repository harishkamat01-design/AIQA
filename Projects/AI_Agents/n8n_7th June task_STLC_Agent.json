        "groqApi": {
          "id": "gfvb93D68YW7YfzG",
          "name": "Groq account"
        }
      }
    },
    {
      "parameters": {
        "operation": "toText",
        "sourceProperty": "output",
        "binaryPropertyName": "testPlanFile",
        "options": {
          "fileName": "test_plan.md"
        }
      },
      "id": "e80f71c4-7843-4991-a710-a0536701dd7f",
