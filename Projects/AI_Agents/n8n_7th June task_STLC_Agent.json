    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a Senior SDET.\n\nGenerate Playwright TypeScript scripts based on the test cases.\n\nTest Cases:\n{{ $json.output.substring(0, 8000) }}\n\nRequirements:\n* Playwright Test Framework\n* TypeScript\n* page.locator()\n* expect assertions\n* One section per test case\n* Use stable selectors\n* Follow Page Object Model concepts\n\nOutput ONLY markdown format.\n\nFocus on the first 30 automation candidate test cases from the CSV.",
        "options": {
          "systemMessage": "You are a Senior SDET specializing in Playwright automation. Output only markdown format with TypeScript code blocks.",
