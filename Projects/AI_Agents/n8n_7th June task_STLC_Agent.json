    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a Senior QA Architect.\n\nAnalyze the following PRD and generate a detailed enterprise-grade Test Plan.\n\nPRD Content:\n{{ $json.text }}\n\nRequirements:\n* Preserve explicit requirements\n* Preserve workflows\n* Preserve business rules\n* Include functional testing\n* Include non-functional testing\n* Include accessibility testing\n* Include security testing\n* Include performance testing\n* Include scalability testing\n* Include integration testing\n* Include entry criteria\n* Include exit criteria\n* Include risks\n* Include assumptions\n* Include traceability\n\nOutput only valid markdown.\n\nBegin with:\n\n# Test Plan",
        "options": {
          "systemMessage": "You are a Senior QA Architect specializing in creating comprehensive test plans.",
          "maxIterations": 10
        }
      },
      "id": "dab85e25-d01d-4ddf-9aeb-bce4b4e82972",
      "name": "Generate Test Plan",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        688,
        400
      ]
    },
    {
      "parameters": {
        "model": "llama-3.3-70b-versatile",
        "options": {
          "maxTokensToSample": 4096,
          "temperature": 0.7
        }
      },
      "id": "ce472ae2-06b4-48c2-9bea-48ac2794ee11",
      "name": "Groq Model - Test Plan",
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        768,
        624
      ],
