    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a Senior QA Engineer.\n\nGenerate exhaustive test cases from the provided Test Plan.\n\nTest Plan:\n{{ $json.output }}\n\nRequirements:\n* Positive scenarios\n* Negative scenarios\n* Boundary scenarios\n* Validation scenarios\n* Accessibility scenarios\n* Security scenarios\n* Integration scenarios\n\nOutput ONLY CSV format.\n\nColumns:\nTestCaseID,Module,Feature,Scenario,PreCondition,TestSteps,ExpectedResult,Priority,AutomationCandidate\n\nMaximum: 100 test cases",
        "options": {
          "systemMessage": "You are a Senior QA Engineer specializing in creating comprehensive test cases. Output only CSV format.",
          "maxIterations": 10
        }
      },
